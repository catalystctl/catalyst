# =============================================================================
# Catalyst Backend Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
# Environment: development | production (affects HSTS, cookie security, logging)
NODE_ENV=development

# Enable HTTP response compression (gzip/br/deflate) — recommended for production
# behind nginx. Set to 'true' to enable, 'false' to disable.
# In self-hosted deployments with nginx in front, nginx handles compression instead.
ENABLE_COMPRESSION=false

# Timezone for scheduled tasks (IANA format)
TZ=UTC

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Panel name shown in emails and UI (default: Catalyst)
APP_NAME=Catalyst

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Backend HTTP port
PORT=3000

# CORS origins (comma-separated). Required in production.
# Example: CORS_ORIGIN=https://catalyst.example.com,https://panel.example.com
CORS_ORIGIN=http://localhost:3000

# Public-facing backend URL (used for generated links, webhooks, auth)
BACKEND_EXTERNAL_ADDRESS=http://localhost:3000

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Additional CORS origins for development (comma-separated)
# DEV_EXTRA_ORIGINS=

# Set to 'false' to disable secure cookies (not recommended outside dev)
# COOKIE_SECURE=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Required. No default — set this before running the backend.
DATABASE_URL=postgresql://catalyst:CHANGE_ME@localhost:5432/catalyst_db

# -----------------------------------------------------------------------------
# Better Auth (required)
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-super-secret-better-auth-key
BETTER_AUTH_URL=http://localhost:3000
PASSKEY_RP_ID=localhost

# -----------------------------------------------------------------------------
# OAuth Providers (optional — leave empty to disable)
# -----------------------------------------------------------------------------
WHMCS_OIDC_CLIENT_ID=
WHMCS_OIDC_CLIENT_SECRET=
WHMCS_OIDC_DISCOVERY_URL=
PAYMENTER_OIDC_CLIENT_ID=
PAYMENTER_OIDC_CLIENT_SECRET=
PAYMENTER_OIDC_DISCOVERY_URL=

# -----------------------------------------------------------------------------
# Console & Server Limits
# -----------------------------------------------------------------------------
# Per-server websocket console output cap in bytes/second (default 262144, clamped to 65536..2097152)
CONSOLE_OUTPUT_BYTE_LIMIT_BYTES=262144

# Maximum disk usage in MB per server
MAX_DISK_MB=10240

# -----------------------------------------------------------------------------
# Suspension
# -----------------------------------------------------------------------------
SUSPENSION_ENFORCED=true
# Policy: block | delete
SUSPENSION_DELETE_POLICY=block
# Whether to block file deletion while suspended
SUSPENSION_DELETE_BLOCKED=true

# -----------------------------------------------------------------------------
# Database Hosts (MySQL)
# -----------------------------------------------------------------------------
DATABASE_HOST_PORT_DEFAULT=3306
DATABASE_HOST_CONNECT_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# SFTP Server (JWT-based authentication)
# -----------------------------------------------------------------------------
SFTP_ENABLED=true
SFTP_PORT=2022
SERVER_DATA_DIR=/var/lib/catalyst/servers
SFTP_HOST_KEY=./sftp_host_key
# Alternative to SFTP_HOST_KEY: provide base64-encoded private key
# SFTP_HOST_KEY_BASE64=
# Maximum file size for SFTP uploads in bytes (default: 104857600 = 100MB)
# SFTP_MAX_FILE_SIZE=104857600

# -----------------------------------------------------------------------------
# Backend URLs (used for generated deployment scripts and webhooks)
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:3000
# API_URL is not currently used by the backend. Use BACKEND_URL or BACKEND_EXTERNAL_ADDRESS instead.
# API_URL=http://localhost:3000/api

# -----------------------------------------------------------------------------
# Plugins (optional)
# -----------------------------------------------------------------------------
PLUGINS_DIR=./plugins
PLUGIN_HOT_RELOAD=false
# Target directory for agent deployment on nodes
# AGENT_TARGET_DIR=/opt/catalyst-agent
# Path to custom agent deployment script
# DEPLOY_SCRIPT_PATH=

# -----------------------------------------------------------------------------
# Backups
# -----------------------------------------------------------------------------
BACKUP_DIR=/var/lib/catalyst/backups
BACKUP_STORAGE_MODE=local
BACKUP_STREAM_DIR=/tmp/catalyst-backup-stream
BACKUP_TRANSFER_DIR=/tmp/catalyst-backup-transfer
# Generate a key: openssl rand -hex 32
BACKUP_CREDENTIALS_ENCRYPTION_KEY=

# Comma-separated list of default webhook URLs
# WEBHOOK_URLS=
# Secret for signing webhook payloads. Generate with: openssl rand -hex 32
# WEBHOOK_SECRET=
# Secret for signing API keys. Generate with: openssl rand -base64 32
# API_KEY_SECRET=

# S3 Backup (optional)
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_PATH_STYLE=false

# SFTP Backup provider is not yet implemented. These vars are reserved for future use:
# BACKUP_SFTP_HOST=
# BACKUP_SFTP_PORT=22
# BACKUP_SFTP_USER=
# BACKUP_SFTP_PASSWORD=
# BACKUP_SFTP_PATH=/backups

# -----------------------------------------------------------------------------
# Optional Services
# -----------------------------------------------------------------------------
# Redis (optional cache/session store)
REDIS_URL=

# -----------------------------------------------------------------------------
# Bootstrap / Seeding
# -----------------------------------------------------------------------------
# WARNING: prisma/seed.ts and the SEED_* variables below are for DEVELOPMENT ONLY.
# Do NOT run seed scripts in production. For new production installs, use the
# /setup web UI that appears on first run, or use bootstrap-production.ts.
#
# Set these to create an initial admin user via bootstrap-production.ts
# CATALYST_ADMIN_EMAIL=
# CATALYST_ADMIN_USERNAME=
# CATALYST_ADMIN_PASSWORD=
# CATALYST_ADMIN_NAME=

# Set to 'true' to allow seed scripts to run in production (NOT recommended)
# SEED_ALLOW_DEFAULT_ADMIN=false

# Seed node configuration — DEVELOPMENT ONLY (prisma/seed.ts)
# SEED_NODE_PUBLIC_ADDRESS=127.0.0.1
# SEED_NODE_HOSTNAME=localhost

# -----------------------------------------------------------------------------
# Scalability & Performance Tuning
# -----------------------------------------------------------------------------
# Database connection pool max size (default 20 — raise to 50 for production)
DB_POOL_MAX=50

# PostgreSQL statement timeout is not currently read from env. Reserved for future use:
# DB_STATEMENT_TIMEOUT_MS=30000

# Max concurrent WebSocket/agent connections
MAX_AGENT_CONNECTIONS=2000

# Max concurrent client (dashboard/API) connections
MAX_CLIENT_CONNECTIONS=15000

# Max concurrent connections per authenticated user
MAX_CONNECTIONS_PER_USER=10

# The following performance vars are hardcoded and not currently read from env:
# SERVER_METRICS_MAX_PER_SEC=1

# AGENT_METRICS_MAX_PER_SEC=1000

# GLOBAL_CONSOLE_OUTPUT_MB_PER_SEC=100

# Max SSE console streams per server (hardcoded to 50)
# MAX_SSE_CONSOLE_PER_SERVER=50

# Max SSE events per server (hardcoded to 100)
# MAX_SSE_EVENTS_PER_SERVER=100

# SSE console sweep interval in milliseconds (hardcoded to 300000)
# SSE_CONSOLE_SWEEP_MS=300000

# File tunnel queue limit per node (hardcoded to 100)
# FILE_TUNNEL_MAX_QUEUE_PER_NODE=100

# File tunnel max concurrent pollers per node (hardcoded to 10)
# FILE_TUNNEL_MAX_POLLERS_PER_NODE=10

# Enable plugin hot-reload in development (disable in production)
PLUGIN_HOT_RELOAD=false

# Number of worker processes (0 = auto / cluster mode off)
WORKERS=0

# Metrics retention in days (default 30)
METRICS_RETENTION_DAYS=30

# Audit log retention is not currently read from env. Reserved for future use:
# AUDIT_RETENTION_DAYS=30

# ------------------------------------------------------------------------------
# Auto Updater (optional)
# ------------------------------------------------------------------------------
# Set to true to enable automatic update checking
AUTO_UPDATE_ENABLED=false
# Check interval in milliseconds (default: 1 hour)
AUTO_UPDATE_INTERVAL_MS=3600000
# Auto-trigger update when available (default: false - only notifies)
AUTO_UPDATE_AUTO_TRIGGER=false
# Path to docker-compose.yml for Docker-based updates
# AUTO_UPDATE_DOCKER_COMPOSE_PATH=/app/docker-compose.yml
