{
	"name": "catalyst-backend",
	"version": "1.1.16",
	"description": "Catalyst - Production-Grade Game Server Management System Backend",
	"main": "dist/index.js",
	"type": "module",
	"engines": {
		"node": ">=20.0.0",
		"bun": ">=1.0.0"
	},
	"overrides": {
		"@peculiar/asn1-schema": "2.6.0"
	},
	"scripts": {
		"dev": "bun --watch src/index.ts -- --host",
		"build": "tsc",
		"start": "bun dist/index.js",
		"db:push": "prisma db push --config prisma/prisma.config.ts",
		"db:migrate": "prisma migrate dev --config prisma/prisma.config.ts",
		"db:studio": "prisma studio --config prisma/prisma.config.ts",
		"db:generate": "prisma generate --config prisma/prisma.config.ts",
		"db:seed": "bun prisma/seed.ts",
		"db:seed:admin": "bun prisma/seed-admin.ts",
		"bulk-servers": "bun scripts/bulk-servers.ts",
		"lint": "eslint src --ext .ts",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "~3.1040.0",
		"@better-auth/passkey": "~1.6.9",
		"@fastify/compress": "^8.3.1",
		"@fastify/cors": "~11.2.0",
		"@fastify/helmet": "~13.0.2",
		"@fastify/multipart": "~10.0.0",
		"@fastify/rate-limit": "~10.3.0",
		"@fastify/swagger": "~9.7.0",
		"@fastify/swagger-ui": "~5.2.6",
		"@fastify/websocket": "~11.2.0",
		"@prisma/adapter-pg": "~7.8.0",
		"@prisma/client": "~7.8.0",
		"@simplewebauthn/server": "~13.3.0",
		"@types/nodemailer": "~8.0.0",
		"better-auth": "~1.6.9",
		"chokidar": "~5.0.0",
		"cron-parser": "~5.5.0",
		"dotenv": "~17.4.2",
		"fastify": "~5.8.5",
		"mysql2": "~3.22.3",
		"nanoid": "~5.1.11",
		"node-cron": "~4.2.1",
		"node-fetch": "~3.3.2",
		"nodemailer": "~8.0.7",
		"pg": "~8.20.0",
		"pino": "~10.3.0",
		"pino-pretty": "~13.1.3",
		"ssh2": "~1.17.0",
		"uuid": "~14.0.0",
		"zod": "~4.4.1",
		"zod-to-json-schema": "^3.25.2"
	},
	"devDependencies": {
		"@eslint/js": "~10.0.1",
		"@types/node": "~25.6.0",
		"@types/uuid": "~11.0.0",
		"@typescript-eslint/eslint-plugin": "~8.59.1",
		"@typescript-eslint/parser": "~8.59.1",
		"@vitest/coverage-v8": "~4.1.5",
		"eslint": "~10.2.1",
		"globals": "~17.5.0",
		"prisma": "~7.8.0",
		"typescript": "~6.0.3",
		"vitest": "~4.1.5"
	}
}
