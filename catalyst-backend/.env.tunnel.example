# =============================================================================
# Catalyst Backend — VS Code Dev Tunnels Overrides
# =============================================================================
# Copy this file to .env.local and replace every PLACEHOLDER with your
# actual tunnel hostname.
#
#   cp .env.tunnel.example .env.local
#   # Edit the values below, then restart: bun run dev
#
# Bun loads .env.local automatically and merges it over .env.
# =============================================================================

# Frontend tunnel (port 5173) — used for CORS, auth redirects, email links
FRONTEND_URL=https://PLACEHOLDER-5173.use.devtunnels.ms

# Backend tunnel (port 3000) — used for generated links, deploy scripts
BACKEND_EXTERNAL_ADDRESS=https://PLACEHOLDER-3000.use.devtunnels.ms
BACKEND_URL=https://PLACEHOLDER-3000.use.devtunnels.ms

# Auth base URL — must match the backend tunnel
BETTER_AUTH_URL=https://PLACEHOLDER-3000.use.devtunnels.ms

# CORS — must include both frontend and backend tunnel origins
CORS_ORIGIN=https://PLACEHOLDER-5173.use.devtunnels.ms,https://PLACEHOLDER-3000.use.devtunnels.ms

# Passkey Relying Party ID — hostname only, no protocol or port
PASSKEY_RP_ID=PLACEHOLDER-5173.use.devtunnels.ms

# Extra dev origins — picked up by DEV_EXTRA_ORIGINS in index.ts & auth.ts
# so the hardcoded dev-mode allowlists also include your tunnel URLs
DEV_EXTRA_ORIGINS=https://PLACEHOLDER-5173.use.devtunnels.ms,https://PLACEHOLDER-3000.use.devtunnels.ms
