# Base URL for API requests (empty = use Vite proxy in dev, relative in prod)
VITE_API_URL=

# Base URL for better-auth (defaults to VITE_API_URL if not set)
VITE_BETTER_AUTH_URL=

# Passkey relying party ID (hostname only, e.g., panel.example.com)
VITE_PASSKEY_RP_ID=

# Playwright / CI
# Set SKIP_WEB_SERVER=true in CI to skip starting the frontend dev server
SKIP_WEB_SERVER=false
