# =============================================================================
# Catalyst Frontend — VS Code Dev Tunnels Overrides
# =============================================================================
# Copy this file to .env.local and replace the placeholder with your tunnel.
#
#   cp .env.tunnel.example .env.local
#   # Edit the values below, then restart: bun run dev
#
# When working remotely, the Vite dev-server proxy handles /api and /ws
# server-side (127.0.0.1 → backend), so the browser only talks to the
# frontend tunnel URL.  Everything just works.
# =============================================================================

# Passkey Relying Party ID — hostname only, no protocol or port
# e.g. b40qp3fc-5173.use.devtunnels.ms
VITE_PASSKEY_RP_ID=PLACEHOLDER-5173.use.devtunnels.ms

# These should stay empty — the Vite proxy routes them server-side.
VITE_API_URL=
VITE_WS_URL=/ws
VITE_BETTER_AUTH_URL=
