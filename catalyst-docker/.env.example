# =============================================================================
# Catalyst — Docker Compose Configuration
# Copy this file to .env and fill in the required values.
# =============================================================================

# --- General -------------------------------------------------------------------
# Set to "development" for plain HTTP (disables HSTS/upgrade-insecure-requests).
# Set to "production" when behind a TLS-terminating reverse proxy.
NODE_ENV=development

# Public URL users will access the panel from (no trailing slash).
# Used for CORS, better-auth, deploy scripts, and email links.
PUBLIC_URL=http://localhost:8080

# Panel name shown in emails and UI (default: Catalyst)
APP_NAME=Catalyst

# Timezone for log timestamps and scheduled tasks
TZ=UTC

# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=catalyst
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD
POSTGRES_DB=catalyst_db
# Optional: expose postgres port on the host (for external tools / pgAdmin)
POSTGRES_PORT=127.0.0.1:5432

# --- Redis --------------------------------------------------------------------
# Leave empty for no password (acceptable when redis is not exposed)
REDIS_PASSWORD=
# Optional: expose redis port on the host
# REDIS_PORT=127.0.0.1:6379

# --- Auth ----------------------------------------------------------------------
# REQUIRED — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Hostname or IP for passkey authentication — must match PUBLIC_URL host
PASSKEY_RP_ID=localhost

# --- Ports --------------------------------------------------------------------
# Bind addresses are 0.0.0.0 by default. Set to 127.0.0.1 to restrict to localhost.
# Note: rootless podman cannot bind ports below 1024. Use 8080 instead of 80.
FRONTEND_PORT=0.0.0.0:8080
BACKEND_PORT=0.0.0.0:3000
SFTP_PORT=0.0.0.0:2022

# --- SFTP ---------------------------------------------------------------------
SFTP_ENABLED=true
# Set to empty string to let the backend auto-generate a host key.
# Must be explicitly set when using podman-compose (variable interpolation quirk).
SFTP_HOST_KEY=
SFTP_HOST_KEY_BASE64=
SFTP_MAX_FILE_SIZE=104857600

# --- Backups ------------------------------------------------------------------
# Storage mode: local (files on disk), s3 (S3-compatible), or stream
BACKUP_STORAGE_MODE=local

# --- S3 Backups (only if BACKUP_STORAGE_MODE=s3) ------------------------------
# BACKUP_S3_BUCKET=
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ACCESS_KEY=
# BACKEND_S3_SECRET_KEY=
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_PATH_STYLE=true

# --- Webhooks (optional) -----------------------------------------------------
# WEBHOOK_URLS=https://your-webhook.example.com/notify
# WEBHOOK_SECRET=your-webhook-signing-secret

# --- Suspension (optional) ----------------------------------------------------
# SUSPENSION_ENFORCED=true
# SUSPENSION_DELETE_BLOCKED=false
# SUSPENSION_DELETE_POLICY=keep

# --- Optional: OAuth providers ------------------------------------------------
# WHMCS_OIDC_CLIENT_ID=
# WHMCS_OIDC_CLIENT_SECRET=
# WHMCS_OIDC_DISCOVERY_URL=
# PAYMENTER_OIDC_CLIENT_ID=
# PAYMENTER_OIDC_CLIENT_SECRET=
# PAYMENTER_OIDC_DISCOVERY_URL=
