# Catalyst Egg Explorer Plugin — Frontend Environment Configuration
# Copy this file to .env and update values as needed

# ── Frontend API Configuration ────────────────────────────────────────────────

# Base URL for Catalyst API endpoints
# - Leave empty for same-origin requests (default, works in most setups)
# - Set to full URL (e.g., https://api.example.com) for cross-origin deployments
# - Used for: template import, nest fetching
VITE_API_URL=
