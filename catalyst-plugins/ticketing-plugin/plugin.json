{
  "name": "ticketing-plugin",
  "version": "2.0.0",
  "displayName": "Ticketing System",
  "description": "Full-featured ticketing system with SLA tracking, advanced filtering, real-time updates, ticket linking, bulk operations, templates, and customizable workflows",
  "author": "Catalyst Team",
  "catalystVersion": ">=1.0.0",
  "permissions": [
    "server.read",
    "user.read"
  ],
  "config": {
    "autoAssignEnabled": { "type": "boolean", "default": false, "description": "Automatically assign new tickets to available users" },
    "autoCloseDays": { "type": "number", "default": 30, "description": "Auto-close resolved tickets after this many days (0 to disable)" },
    "defaultPriority": { "type": "select", "default": "medium", "description": "Default priority for new tickets", "options": ["critical", "high", "medium", "low", "minimal"] },
    "defaultCategory": { "type": "select", "default": "Support", "description": "Default category for new tickets", "options": ["Bug Report", "Feature Request", "Support", "Billing", "Infrastructure", "Security", "Documentation", "Other"] },
    "responseSlaHours": { "type": "number", "default": 4, "description": "SLA: maximum hours before first response" },
    "resolutionSlaHours": { "type": "number", "default": 48, "description": "SLA: maximum hours before resolution" },
    "maxEscalationLevel": { "type": "number", "default": 3, "description": "Maximum escalation level (0-3)" }
  },
  "events": {
    "ticket:created": { "payload": { "ticketId": "string", "ticketNumber": "string" } },
    "ticket:updated": { "payload": { "ticketId": "string", "changes": "object" } },
    "ticket:deleted": { "payload": { "ticketId": "string" } },
    "ticket:comment-added": { "payload": { "ticketId": "string", "commentId": "string" } },
    "ticket:status-changed": { "payload": { "ticketId": "string", "from": "string", "to": "string" } },
    "ticket:assigned": { "payload": { "ticketId": "string", "assigneeId": "string" } },
    "ticket:escalated": { "payload": { "ticketId": "string", "level": "number" } },
    "ticket:sla-breached": { "payload": { "ticketId": "string", "type": "string" } },
    "ticket:bulk-updated": { "payload": { "ticketIds": "string[]", "action": "string" } }
  },
  "backend": { "entry": "backend/index.js" },
  "frontend": { "entry": "frontend/index.ts", "hasTabs": true }
}
