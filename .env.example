# =============================================================================
# Catalyst - Docker Compose Environment
# Copy this file to .env and fill in the values.
# Then run: docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Required — set these before first run
# -----------------------------------------------------------------------------

# Strong secret for Better Auth sessions. Generate one:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost

# PostgreSQL password (also used by backend to connect internally)
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Optional — defaults are fine for local testing
# -----------------------------------------------------------------------------

# Environment: production | development
NODE_ENV=production

# Timezone (IANA format)
TZ=UTC

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Public-facing URLs
BACKEND_EXTERNAL_ADDRESS=http://localhost
FRONTEND_URL=http://localhost
CORS_ORIGIN=http://localhost

# Passkey/WebAuthn relying party ID
PASSKEY_RP_ID=localhost

# PostgreSQL
POSTGRES_USER=catalyst
POSTGRES_DB=catalyst_db
POSTGRES_PORT=127.0.0.1:5432

# Redis (leave empty to skip Redis features)
REDIS_URL=redis://redis:6379
REDIS_PORT=127.0.0.1:6379

# Port bindings (host)
BACKEND_PORT=127.0.0.1:3000
FRONTEND_PORT=80
SFTP_PORT=127.0.0.1:2022

# SFTP
SFTP_ENABLED=true

# Backups
BACKUP_STORAGE_MODE=local
# BACKUP_CREDENTIALS_ENCRYPTION_KEY=  # openssl rand -hex 32

# Server limits
# MAX_DISK_MB=10240
# CONSOLE_OUTPUT_BYTE_LIMIT_BYTES=262144

# Suspension
SUSPENSION_ENFORCED=true
SUSPENSION_DELETE_POLICY=block
SUSPENSION_DELETE_BLOCKED=true

# -----------------------------------------------------------------------------
# OAuth Providers (optional — leave empty to disable)
# -----------------------------------------------------------------------------
# WHMCS_OIDC_CLIENT_ID=
# WHMCS_OIDC_CLIENT_SECRET=
# WHMCS_OIDC_DISCOVERY_URL=
# PAYMENTER_OIDC_CLIENT_ID=
# PAYMENTER_OIDC_CLIENT_SECRET=
# PAYMENTER_OIDC_DISCOVERY_URL=

# -----------------------------------------------------------------------------
# S3 Backups (optional)
# -----------------------------------------------------------------------------
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_BUCKET=
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# BACKUP_S3_PATH_STYLE=false
